{
  "name": "the-nexus",
  "version": "1.0.0",
  "description": "CDC 인격형 AI 인터페이스 - 의장님과 15사도를 연결하는 중추 플랫폼",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "vue": "^3.3.0",
    "cytoscape": "^3.28.1",
    "cytoscape-cose-bilkent": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "jsdom": "^29.1.1",
    "vite": "^5.0.0",
    "vitest": "^4.1.6",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.cdc.nexus",
    "productName": "The Nexus",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
