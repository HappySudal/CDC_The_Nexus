{
  "tag-prefix": "nexus-v",
  "header": "# The Nexus — Changelog\n\nAll notable changes to The Nexus (`PJT_CDC_The_Nexus`) are documented here.\nFormat follows [Conventional Commits](https://www.conventionalcommits.org/).\n",
  "types": [
    { "type": "feat", "section": "✨ Features" },
    { "type": "fix", "section": "🐛 Bug Fixes" },
    { "type": "perf", "section": "⚡ Performance" },
    { "type": "refactor", "section": "♻️ Refactoring" },
    { "type": "test", "section": "🧪 Tests" },
    { "type": "build", "section": "📦 Build System" },
    { "type": "ci", "section": "🤖 CI/CD" },
    { "type": "docs", "section": "📚 Documentation", "hidden": false },
    { "type": "chore", "section": "🔧 Chores", "hidden": false },
    { "type": "style", "hidden": true },
    { "type": "revert", "section": "⏪ Reverts" }
  ],
  "commitUrlFormat": "https://github.com/cdc/nexus/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/cdc/nexus/compare/{{previousTag}}...{{currentTag}}",
  "releaseCommitMessageFormat": "chore(release): nexus-v{{currentTag}} — automated by standard-version",
  "skip": {
    "tag": false
  },
  "bumpFiles": [
    {
      "filename": "package.json",
      "type": "json"
    }
  ]
}
